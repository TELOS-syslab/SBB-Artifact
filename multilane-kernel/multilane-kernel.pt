+asmlinkage long sys_uintr_kernel_handler_enable(void);
+asmlinkage long sys_uintr_kernel_handler_disable(void);
+asmlinkage long sys_uintr_register_timer_int(u32 hz, u8 uinv);
+asmlinkage long sys_uintr_unregister_timer_int(void);
+asmlinkage long sys_read_timer_msr(int cpu);
